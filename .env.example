# 이 파일을 .env 로 복사한 뒤 키를 채우세요:  cp .env.example .env
# (.env 는 비밀이므로 git/이미지에 포함되지 않습니다)

# 필수 — Gemini(google.genai) API 키
GEMINI_API_KEY=

# 선택 — Claude(Anthropic). 채우면 모델 드롭다운에 Claude 가 나타납니다. 비우면 숨김.
ANTHROPIC_API_KEY=

# 선택 — 로컬 Ollama 서버 주소.
#   · 로컬(도커 아님)에서 직접 실행 시:      http://localhost:11434
#   · 도커로 실행 시: docker-compose.yml 이 host.docker.internal 로 자동 설정하므로 건드릴 필요 없음
OLLAMA_HOST=http://localhost:11434
